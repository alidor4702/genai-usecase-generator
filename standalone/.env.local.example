# Copy to .env.local for local development.
#
# Why: Next.js dev server's rewrite proxy buffers SSE responses, which
# breaks the live activity feed (events arrive all at once when the run
# completes instead of streaming). Setting NEXT_PUBLIC_API_URL routes
# api.ts requests directly to the FastAPI backend, bypassing the rewrite.
#
# Backend CORS is wide-open in dev so cross-origin Just Works.
# In production set NEXT_PUBLIC_API_URL to the deployed backend URL
# (e.g. https://genai-usecase-generator-api.onrender.com).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
